{
  "installCommand": "if [ -d \"flutter\" ]; then echo \"Flutter exists\"; else git clone https://github.com/flutter/flutter.git -b stable; fi",
  "buildCommand": "P=$(dirname $(find . -path ./flutter -prune -o -name pubspec.yaml -print|head -1));cd $P;$OLDPWD/flutter/bin/flutter build web --no-tree-shake-icons;cd $OLDPWD;cp -r $P/build/web out",
  "outputDirectory": "out",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
